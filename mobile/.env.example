# Expo public env vars (inlined at build). Use HTTPS for production APK / store builds.

# Deployed MedWaste SPA (Vite) — WebView loads this URL
EXPO_PUBLIC_WEB_APP_URL=https://your-frontend.example.com

# Same value you use for VITE_API_URL — Railway API root, HTTPS, no trailing slash
EXPO_PUBLIC_API_URL=https://your-backend.up.railway.app

# MedWaste API — copy to `.env` for local use; on Railway set variables in the dashboard.

# HTTP port inside the container (Railway sets PORT automatically)
PORT=5000
HOST=0.0.0.0

# Comma-separated browser origins allowed for CORS + Socket.io (your deployed SPA / WebView URL, HTTPS).
# Localhost and Capacitor WebView origins are always allowed by default:
# capacitor://localhost, http://localhost, https://localhost
CLIENT_URL=https://your-frontend.example.com

# Optional: extra origins (e.g. a second staging URL) without editing CLIENT_URL
# CORS_EXTRA_ORIGINS=

# Public base URL of this API (for dev scripts like mockSensor.js)
# BACKEND_BASE_URL=https://your-api.up.railway.app

# Optional external ML service (HTTPS). If unset or unreachable, bin predictions use a safe fallback.
# ML_SERVICE_URL=https://your-ml-service.example.com

POSTGRES_URI=
MONGO_URI=
REDIS_URL=

JWT_SECRET=
EMAIL_USER=
EMAIL_PASS=
ALERT_RECIPIENT=

ENABLE_POSTGRES=true
ENABLE_MONGO=true
ENABLE_REDIS=true
